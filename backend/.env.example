# Copy to .env and adjust. The app also runs with these defaults if no env vars
# are set — but you MUST change JWT_SECRET in production.

APP_ENV=development
PORT=8080

JWT_SECRET=dev-secret-change-me
JWT_EXPIRY_HOURS=24

# Storage: "memory" (default, no infrastructure needed) or "postgres".
STORAGE_PROVIDER=memory
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance_app?sslmode=disable

# Redis (leaderboard cache + price cache). Leave empty to disable Redis.
REDIS_URL=redis://localhost:6379/0

# Price source: "mock" (deterministic, offline) or "yahoo" (prototype only).
PRICE_PROVIDER=mock
PRICE_CACHE_TTL_SECONDS=300

BASE_CURRENCY=USD

# Background jobs (sprint upkeep + leaderboard cache refresh).
ENABLE_BACKGROUND_WORKERS=true
LEADERBOARD_REFRESH_INTERVAL_SECONDS=60
